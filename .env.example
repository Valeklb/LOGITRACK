# --- Backend (Railway) ---
PORT=3000
DATABASE_PATH=logistic.db

# --- Vercel (proxy /api → Railway) ---
# URL pública do serviço no Railway (sem barra no final)
RAILWAY_API_URL=https://sua-api.up.railway.app

# --- Vercel (WebSocket do motorista — aponta direto pro Railway) ---
# Obrigatório para notificações push do motorista
VITE_WS_URL=https://sua-api.up.railway.app

# --- Alternativa: chamar Railway direto (sem proxy Vercel) ---
# Se definir VITE_API_URL, o frontend ignora o proxy e vai direto ao Railway
# VITE_API_URL=https://sua-api.up.railway.app
