# --- Backend (Railway) ---
# Porta injetada automaticamente pelo Railway
PORT=3000

# Caminho do SQLite (use volume no Railway para persistência)
DATABASE_PATH=logistic.db

# --- Frontend (Vercel) — obrigatório em produção ---
# URL pública da API no Railway (sem barra no final)
VITE_API_URL=https://sua-api.up.railway.app

# WebSocket (opcional; usa VITE_API_URL se omitido)
# VITE_WS_URL=https://sua-api.up.railway.app
